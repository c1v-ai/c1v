{
  "story_id": "m7-interfaces",
  "version": "1.0.0",
  "decisions": [
    {
      "decision_id": "iface_auth_protocol",
      "target_field": "interface_specs[IF.AUTH].protocol",
      "inputs": [
        { "name": "user_type", "source": "module-0/intake-discriminators" },
        { "name": "data_sensitivity", "source": "module-0/intake-discriminators" }
      ],
      "function": {
        "type": "decision_tree",
        "rules": [
          {
            "rule_id": "iface_auth_oauth_pii",
            "if": { "user_type_in": ["consumer_app", "enterprise_app"], "data_sensitivity_in": ["pii", "phi"] },
            "value": "OAUTH2_PKCE",
            "base_confidence": 0.93
          },
          {
            "rule_id": "iface_auth_oauth_default",
            "if": { "user_type_in": ["consumer_app", "enterprise_app"] },
            "value": "OAUTH2_AUTH_CODE",
            "base_confidence": 0.91
          },
          {
            "rule_id": "iface_auth_internal",
            "if": { "user_type": "internal_tool" },
            "value": "API_KEY",
            "base_confidence": 0.90
          },
          {
            "default": {
              "rule_id": "iface_auth_default",
              "value": "OAUTH2_AUTH_CODE",
              "base_confidence": 0.78
            }
          }
        ]
      },
      "confidence_modifiers": [
        { "when": "regulatory_override", "delta": 0.04, "cap": 0.99 },
        { "when": "rule_default_branch", "delta": -0.10 }
      ],
      "auto_fill_threshold": 0.90
    },
    {
      "decision_id": "iface_persistence_protocol",
      "target_field": "interface_specs[IF.PERSIST].protocol",
      "inputs": [
        { "name": "data_shape", "source": "module-1/data-flows" }
      ],
      "function": {
        "type": "decision_tree",
        "rules": [
          {
            "rule_id": "iface_persist_postgres_wire",
            "if": { "data_shape_in": ["relational", "document"] },
            "value": "POSTGRES_WIRE",
            "base_confidence": 0.94
          },
          {
            "default": {
              "rule_id": "iface_persist_default",
              "value": "POSTGRES_WIRE",
              "base_confidence": 0.80
            }
          }
        ]
      },
      "confidence_modifiers": [
        { "when": "rule_default_branch", "delta": -0.05 }
      ],
      "auto_fill_threshold": 0.90
    },
    {
      "decision_id": "iface_telemetry_protocol",
      "target_field": "interface_specs[IF.TEL].protocol",
      "inputs": [
        { "name": "deployment_target", "source": "module-0/intake-discriminators" }
      ],
      "function": {
        "type": "decision_tree",
        "rules": [
          {
            "rule_id": "iface_tel_otel_serverless",
            "if": { "deployment_target": "serverless" },
            "value": "OTLP_HTTP",
            "base_confidence": 0.91
          },
          {
            "rule_id": "iface_tel_otel_container",
            "if": { "deployment_target": "container" },
            "value": "OTLP_GRPC",
            "base_confidence": 0.91
          },
          {
            "default": {
              "rule_id": "iface_tel_default",
              "value": "OTLP_HTTP",
              "base_confidence": 0.80
            }
          }
        ]
      },
      "confidence_modifiers": [
        { "when": "rule_default_branch", "delta": -0.05 }
      ],
      "auto_fill_threshold": 0.90
    }
  ]
}

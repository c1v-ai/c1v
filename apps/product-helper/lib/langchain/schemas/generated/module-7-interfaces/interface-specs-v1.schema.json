{
  "type": "object",
  "properties": {
    "_schema": {
      "type": "string",
      "const": "module-7b.interface-specs.v1"
    },
    "_output_path": {
      "type": "string"
    },
    "_upstream_refs": {
      "type": "object",
      "properties": {
        "n2_matrix": {
          "type": "string"
        },
        "nfrs": {
          "type": "string"
        },
        "fmea_early": {
          "type": "string"
        },
        "decision_network": {
          "type": "string"
        }
      },
      "required": [
        "n2_matrix",
        "nfrs",
        "fmea_early",
        "decision_network"
      ],
      "additionalProperties": false
    },
    "produced_at": {
      "type": "string"
    },
    "produced_by": {
      "type": "string"
    },
    "system_name": {
      "type": "string"
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "interface_id": {
            "type": "string",
            "pattern": "^IF\\.[0-9]{2}$",
            "description": "x-ui-surface=section:Interface Spec > Header — IF.NN matching n2_matrix.v1 row."
          },
          "n2_row_ref": {
            "type": "string",
            "description": "x-ui-surface=internal:cross-ref — path to n2_matrix.v1.json + row id (e.g., \"module-7-interfaces/n2_matrix.v1.json#IF.01\")."
          },
          "producer": {
            "type": "string",
            "pattern": "^F\\.\\d+$"
          },
          "consumer": {
            "type": "string",
            "pattern": "^F\\.\\d+$"
          },
          "payload_name": {
            "type": "string",
            "minLength": 1
          },
          "protocol": {
            "type": "string",
            "minLength": 1
          },
          "sync_style": {
            "type": "string",
            "enum": [
              "sync",
              "async",
              "batch",
              "streaming"
            ]
          },
          "sla": {
            "type": "object",
            "properties": {
              "p95_latency_ms": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "availability_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "throughput_ceiling_rps": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "derivation_sources": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "nfr"
                        },
                        "nfr_id": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "kind",
                        "nfr_id"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "kb-8-atlas"
                        },
                        "entry_path": {
                          "type": "string",
                          "minLength": 3
                        },
                        "field_path": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "kind",
                        "entry_path",
                        "field_path"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "fmea"
                        },
                        "fmea_row_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "detectability_requirement": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "kind",
                        "fmea_row_id",
                        "detectability_requirement"
                      ],
                      "additionalProperties": false
                    }
                  ],
                  "description": "x-ui-surface=section:Interface Spec > SLA > Source — where the SLA target came from."
                },
                "minItems": 1
              },
              "math_derivation": {
                "type": "object",
                "properties": {
                  "formula": {
                    "type": "string",
                    "description": "x-ui-surface=section:Requirement Detail > Design Rationale — LaTeX-like or plain-English formula (e.g., \"p95 = base + queueing_delay(λ, μ)\")."
                  },
                  "inputs": {
                    "type": "object",
                    "additionalProperties": {
                      "type": [
                        "number",
                        "string"
                      ]
                    },
                    "default": {},
                    "description": "x-ui-surface=internal:math-derivation-resolver — named inputs to the formula (e.g., {\"lambda\": 150, \"mu\": 200})."
                  },
                  "kb_source": {
                    "type": "string",
                    "description": "x-ui-surface=section:Requirement Detail > Design Rationale — KB filename (matches softwareArchRefSchema or \"inline\") that sourced the formula."
                  },
                  "kb_section": {
                    "type": "string",
                    "description": "x-ui-surface=section:Requirement Detail > Design Rationale — optional heading/anchor within the KB file (e.g., \"§P95 envelope\")."
                  },
                  "result": {
                    "type": [
                      "number",
                      "string"
                    ],
                    "description": "x-ui-surface=section:Requirement Detail > Design Rationale — computed value, if the formula is evaluated at generation time."
                  }
                },
                "required": [
                  "formula",
                  "kb_source"
                ],
                "additionalProperties": false,
                "description": "x-ui-surface=section:Requirement Detail > Design Rationale — math derivation for a numeric field (formula + inputs + KB citation)."
              }
            },
            "required": [
              "p95_latency_ms",
              "availability_pct",
              "throughput_ceiling_rps",
              "derivation_sources",
              "math_derivation"
            ],
            "additionalProperties": false,
            "description": "x-ui-surface=section:Interface Spec > SLA — per-interface service-level targets."
          },
          "retry": {
            "type": "object",
            "properties": {
              "max_attempts": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              },
              "backoff_ms": {
                "type": "integer",
                "minimum": 0
              },
              "strategy": {
                "type": "string",
                "enum": [
                  "fixed",
                  "exponential",
                  "exponential_jitter"
                ],
                "default": "exponential_jitter"
              },
              "retry_on": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            },
            "required": [
              "max_attempts",
              "backoff_ms"
            ],
            "additionalProperties": false,
            "description": "x-ui-surface=section:Interface Spec > Retry — retry policy contract."
          },
          "timeout_ms": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "circuit_breaker": {
            "type": "object",
            "properties": {
              "error_rate_threshold_pct": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "min_requests_before_trip": {
                "type": "integer",
                "minimum": 1
              },
              "open_state_duration_ms": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "error_rate_threshold_pct",
              "min_requests_before_trip",
              "open_state_duration_ms"
            ],
            "additionalProperties": false,
            "description": "x-ui-surface=section:Interface Spec > Circuit Breaker — failure-gate contract."
          },
          "auth": {
            "type": "string",
            "enum": [
              "none",
              "api-key",
              "bearer-jwt",
              "oauth2",
              "mtls",
              "session-cookie",
              "in-process"
            ]
          },
          "error_handling": {
            "type": "object",
            "properties": {
              "error_schema_ref": {
                "type": "string",
                "minLength": 3
              },
              "status_codes": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 100,
                  "maximum": 599
                },
                "minItems": 1
              },
              "idempotency": {
                "type": "string",
                "enum": [
                  "required",
                  "advisory",
                  "none"
                ],
                "default": "advisory"
              }
            },
            "required": [
              "error_schema_ref",
              "status_codes"
            ],
            "additionalProperties": false,
            "description": "x-ui-surface=section:Interface Spec > Errors — error contract and idempotency."
          }
        },
        "required": [
          "interface_id",
          "n2_row_ref",
          "producer",
          "consumer",
          "payload_name",
          "protocol",
          "sync_style",
          "sla",
          "retry",
          "timeout_ms",
          "circuit_breaker",
          "auth",
          "error_handling"
        ],
        "additionalProperties": false,
        "description": "x-ui-surface=section:Interface Spec — full formal contract per IF.NN."
      },
      "minItems": 1
    },
    "chain_budgets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "chain_id": {
            "type": "string",
            "minLength": 1
          },
          "hops": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^IF\\.[0-9]{2}$",
              "description": "x-ui-surface=section:Interface Spec > Header — IF.NN matching n2_matrix.v1 row."
            },
            "minItems": 1
          },
          "sum_p95_latency_ms": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "user_facing_nfr_p95_ms": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "budget_ok": {
            "type": "boolean"
          }
        },
        "required": [
          "chain_id",
          "hops",
          "sum_p95_latency_ms",
          "user_facing_nfr_p95_ms",
          "budget_ok"
        ],
        "additionalProperties": false,
        "description": "x-ui-surface=section:Latency Chain Budget — Σ p95_i per chain vs NFR target."
      },
      "default": []
    }
  },
  "required": [
    "_schema",
    "_output_path",
    "_upstream_refs",
    "produced_at",
    "produced_by",
    "system_name",
    "interfaces"
  ],
  "additionalProperties": false,
  "description": "x-ui-surface=page:/system-design/interfaces — interface_specs.v1 root artifact.",
  "title": "InterfaceSpecsV1",
  "$schema": "http://json-schema.org/draft-07/schema#"
}

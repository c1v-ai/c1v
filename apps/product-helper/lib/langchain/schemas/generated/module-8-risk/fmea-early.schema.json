{
  "type": "object",
  "properties": {
    "_schema": {
      "type": "string",
      "const": "module-8.fmea-early.v1"
    },
    "_output_path": {
      "type": "string"
    },
    "_upstream_refs": {
      "type": "object",
      "properties": {
        "ffbd": {
          "type": "string"
        },
        "n2_matrix": {
          "type": "string"
        },
        "data_flows": {
          "type": "string"
        },
        "rating_scales": {
          "type": "string"
        }
      },
      "required": [
        "ffbd",
        "n2_matrix",
        "data_flows",
        "rating_scales"
      ],
      "additionalProperties": false
    },
    "produced_at": {
      "type": "string"
    },
    "produced_by": {
      "type": "string"
    },
    "system_name": {
      "type": "string"
    },
    "rating_scales_version": {
      "type": "string",
      "description": "Version identifier of rating_scales.json used at build time."
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FM\\.\\d{2,}$",
            "description": "Stable failure-mode id FM.NN."
          },
          "target_ref": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "function",
                  "interface",
                  "data_flow"
                ]
              },
              "ref": {
                "type": "string",
                "description": "F.N | IF.NN | DE.NN — MUST resolve in the upstream artifact for its kind."
              }
            },
            "required": [
              "kind",
              "ref"
            ],
            "additionalProperties": false,
            "description": "Target of a failure mode — must resolve in upstream artifact."
          },
          "failure_mode": {
            "type": "string",
            "description": "Short description of the failure mode."
          },
          "potential_cause": {
            "type": "string"
          },
          "potential_effect": {
            "type": "string"
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4,
            "description": "Per rating_scales.json severity scale (1..4)."
          },
          "likelihood": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Per rating_scales.json likelihood scale (1..5)."
          },
          "detectability": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Per rating_scales.json detectability scale (1..5; higher = harder)."
          },
          "rpn": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "severity * likelihood per rating_scales.rpn_matrix."
          },
          "criticality_category": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM LOW",
              "MEDIUM",
              "MEDIUM HIGH",
              "HIGH"
            ],
            "description": "Derived from rpn via rating_scales.criticality_ranges."
          },
          "candidate_mitigation": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Stable id within this FMEA row (e.g., \"M1\", \"M2\")."
                },
                "summary": {
                  "type": "string"
                },
                "kb_refs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": [],
                  "description": "KB file refs supporting this mitigation option."
                }
              },
              "required": [
                "id",
                "summary"
              ],
              "additionalProperties": false,
              "description": "One candidate mitigation option; no commitment implied."
            },
            "default": [],
            "description": "Options only; no commitment."
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "target_ref",
          "failure_mode",
          "potential_cause",
          "potential_effect",
          "severity",
          "likelihood",
          "detectability",
          "rpn",
          "criticality_category"
        ],
        "additionalProperties": false,
        "description": "Single FMEA row (FM.NN)."
      },
      "minItems": 1
    },
    "xlsx_path": {
      "type": "string",
      "description": "Optional relative path to xlsx render (via scripts/artifact-generators/gen-fmea.py)."
    }
  },
  "required": [
    "_schema",
    "_output_path",
    "_upstream_refs",
    "produced_at",
    "produced_by",
    "system_name",
    "rating_scales_version",
    "failure_modes"
  ],
  "additionalProperties": false,
  "description": "Canonical FMEA-early (v1) artifact.",
  "title": "FmeaEarly",
  "$schema": "http://json-schema.org/draft-07/schema#"
}

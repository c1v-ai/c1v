{
  "type": "object",
  "properties": {
    "_schema": {
      "type": "string",
      "description": "x-ui-surface=internal:schema-drift-check — fully-qualified schema id (e.g., \"module-2.phase-6-requirements-table.v1\")."
    },
    "_output_path": {
      "type": "string",
      "description": "x-ui-surface=internal:xlsx-marshaller — target filesystem path for the marshalled artifact."
    },
    "_phase_status": {
      "type": "string",
      "enum": [
        "planned",
        "in_progress",
        "complete",
        "needs_revision"
      ],
      "description": "x-ui-surface=page-header — workflow state (drives C4 requirements-table branch)."
    },
    "_columns_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "column_letter": {
            "type": "string",
            "pattern": "^[A-Z]{1,3}$",
            "description": "x-ui-surface=internal:xlsx-marshaller — Excel column letter (A..AZ..)."
          },
          "field_name": {
            "type": "string",
            "description": "x-ui-surface=internal:xlsx-marshaller — Zod field path emitted in this column."
          },
          "header_text": {
            "type": "string",
            "description": "x-ui-surface=internal:xlsx-marshaller — text printed in the header row."
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "x-ui-surface=internal:xlsx-marshaller — preferred column width in Excel units."
          },
          "type_hint": {
            "type": "string",
            "enum": [
              "text",
              "number",
              "date",
              "bool",
              "enum",
              "json",
              "formula"
            ],
            "description": "x-ui-surface=internal:xlsx-marshaller — Excel cell-type hint for the marshaller."
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "x-ui-surface=internal:xlsx-marshaller — whether marshaller should error on null."
          }
        },
        "required": [
          "column_letter",
          "field_name",
          "header_text"
        ],
        "additionalProperties": false,
        "description": "x-ui-surface=internal:xlsx-marshaller — single column-layout instruction (first-class per C5)."
      },
      "description": "x-ui-surface=internal:xlsx-marshaller — optional layout instructions (first-class per C5)."
    },
    "_insertions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "phase_slug": {
            "type": "string",
            "description": "x-ui-surface=internal:methodology-drift-check — phase that received this insertion."
          },
          "field_path": {
            "type": "string",
            "description": "x-ui-surface=internal:methodology-drift-check — dotted path within the phase schema (e.g., \"rows[].math_derivation\")."
          },
          "introduced_in": {
            "type": "string",
            "description": "x-ui-surface=internal:methodology-drift-check — schema semver where this field was added."
          },
          "rationale": {
            "type": "string",
            "description": "x-ui-surface=section:Methodology Lineage — reviewer-facing reason the insertion was made."
          },
          "kb_source": {
            "type": "string",
            "description": "x-ui-surface=section:Methodology Lineage — KB file that motivated the insertion, if any."
          }
        },
        "required": [
          "phase_slug",
          "field_path",
          "introduced_in",
          "rationale"
        ],
        "additionalProperties": false,
        "description": "x-ui-surface=section:Methodology Lineage — methodology insertion (first-class per C5)."
      },
      "description": "x-ui-surface=section:Methodology Lineage — optional methodology insertions applied to this phase (first-class per C5)."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "phase_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18,
          "description": "x-ui-surface=page-header — methodology phase number (0-18) per F13/4 Decision Matrix module."
        },
        "phase_slug": {
          "type": "string",
          "description": "x-ui-surface=page-header — URL-safe slug (e.g., \"requirements-table\"). Also the xlsx sheet slug."
        },
        "phase_name": {
          "type": "string",
          "description": "x-ui-surface=page-header — human-facing phase title (e.g., \"Phase 6 — Extract Requirements Table\")."
        },
        "schema_version": {
          "type": "string",
          "description": "x-ui-surface=page-header — Zod schema semver (e.g., \"1.0.0\") for drift-detection."
        },
        "project_id": {
          "type": "integer",
          "description": "x-ui-surface=page-header — parent project id; keys workbook + PDF filename."
        },
        "project_name": {
          "type": "string",
          "description": "x-ui-surface=page-header — project display name; rendered at top and used as xlsx workbook title."
        },
        "author": {
          "type": "string",
          "description": "x-ui-surface=page-header — emitting agent or human reviewer identifier."
        },
        "generated_at": {
          "type": "string",
          "description": "x-ui-surface=page-header — ISO-8601 timestamp of emission."
        },
        "generator": {
          "type": "string",
          "description": "x-ui-surface=page-header — tool that produced this artifact (e.g., \"product-helper@0.1.0\")."
        },
        "revision": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "x-ui-surface=page-header — monotonic revision counter per (project, phase)."
        }
      },
      "required": [
        "phase_number",
        "phase_slug",
        "phase_name",
        "schema_version",
        "project_id",
        "project_name",
        "author",
        "generated_at",
        "generator"
      ],
      "additionalProperties": false,
      "description": "x-ui-surface=page-header — dual-surface header (M4-widened phase_number range 0-18)."
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "decision_node_id": {
            "type": "string",
            "pattern": "^DN\\.[0-9]{2}$",
            "description": "x-ui-surface=section:Decision Node > Header — ID pattern DN.NN (e.g., DN.01 = choose orchestration runtime)."
          },
          "alternative_id": {
            "type": "string",
            "pattern": "^[A-Z]$",
            "description": "x-ui-surface=section:Decision Node > Alternatives — single uppercase letter ID."
          },
          "criterion_id": {
            "type": "string",
            "pattern": "^PC-[0-9]{2}$"
          },
          "bound_to": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "kb-8-atlas"
                  },
                  "entry_path": {
                    "type": "string",
                    "minLength": 3
                  },
                  "field_path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sample_size": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "source",
                  "entry_path",
                  "field_path",
                  "sample_size"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "kb-shared"
                  },
                  "kb_file": {
                    "type": "string",
                    "minLength": 3
                  },
                  "section": {
                    "type": "string"
                  }
                },
                "required": [
                  "source",
                  "kb_file"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "nfr"
                  },
                  "nfr_id": {
                    "type": "string",
                    "pattern": "^NFR\\.[0-9]{2,}$"
                  }
                },
                "required": [
                  "source",
                  "nfr_id"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "fmea"
                  },
                  "fmea_row_id": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "source",
                  "fmea_row_id"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "inferred"
                  },
                  "rationale": {
                    "type": "string",
                    "minLength": 5
                  }
                },
                "required": [
                  "source",
                  "rationale"
                ],
                "additionalProperties": false
              }
            ],
            "description": "x-ui-surface=section:Prior Binding > Row — discriminated union over prior source."
          },
          "provisional": {
            "type": "boolean",
            "default": false
          },
          "hash_chain_prev": {
            "type": "string",
            "pattern": "^[a-f0-9]{8,64}$|^GENESIS$",
            "description": "x-ui-surface=internal:audit — previous audit-row hash for decision_audit chain."
          }
        },
        "required": [
          "decision_node_id",
          "alternative_id",
          "criterion_id",
          "bound_to",
          "hash_chain_prev"
        ],
        "additionalProperties": false,
        "description": "x-ui-surface=section:Prior Binding > Row — provenance manifest row tying a score to its empirical source."
      },
      "minItems": 1
    },
    "kb_8_entries_consulted": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "_schema",
    "_output_path",
    "_phase_status",
    "metadata",
    "bindings"
  ],
  "additionalProperties": false,
  "description": "x-ui-surface=page-header — base phase envelope extended by every Module 2 phase.",
  "title": "Phase19EmpiricalPriorBinding",
  "$schema": "http://json-schema.org/draft-07/schema#"
}

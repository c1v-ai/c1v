{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qfd-legacy.schema.json",
  "title": "QFD Legacy (gen-qfd.py adapter)",
  "description": "Permissive shape consumed by scripts/artifact-generators/gen-qfd.py. Mirrors the legacy system-design/kb-upgrade-v2/module-6-qfd/c1v_QFD.json structure. The strict, audit-grade shape lives in apps/product-helper/lib/langchain/schemas/module-6-hoq/ (hoqV1Schema). This adapter exists only to drive the existing xlsx generator without coupling it to the new schema split (T6 Wave 4).",
  "type": "object",
  "required": [
    "metadata",
    "front_porch",
    "second_floor",
    "main_floor",
    "roof",
    "back_porch",
    "basement"
  ],
  "additionalProperties": true,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["project_title", "developed_by", "last_updated"],
      "additionalProperties": true
    },
    "front_porch": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pc_id", "full_attribute", "short_name", "relative_importance", "direction_of_change"],
        "additionalProperties": true
      }
    },
    "second_floor": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ec_id", "name", "unit", "direction_of_change"],
        "additionalProperties": true
      }
    },
    "main_floor": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "integer" }
      }
    },
    "roof": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "back_porch": {
      "type": "object",
      "required": ["_competitor_b_name", "_competitor_c_name"],
      "additionalProperties": true
    },
    "basement": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["unit", "competitor_b", "competitor_c", "external_threshold", "target", "technical_difficulty", "estimated_cost"],
        "additionalProperties": true
      }
    }
  }
}

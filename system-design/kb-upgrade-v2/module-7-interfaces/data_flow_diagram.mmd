%% c1v Dual-Mode Platform — Top-level Data Flow Diagram
%% Module 6 — Defining Interfaces (2026-04-20)
%% Source: system-design/module-7-interfaces/n2_chart.json (IF-01..IF-32 + IF-EXT-01..IF-EXT-10)
%% Every arrow label carries the data summary + EC budget driving it.

flowchart LR
    %% =============================================================
    %% External actors (outside the c1v boundary)
    %% =============================================================
    subgraph EXT_ACTORS["External Actors"]
        direction TB
        FOUND[Founders / PMs /<br/>Engineers / Admins]
        IDP[Identity Providers<br/>OIDC / SAML]
        LLM[LLM Providers<br/>Anthropic / OpenAI / local]
        VCS[Version Control<br/>git / HTTPS]
        CUST[Customer Prod Systems +<br/>Observability Tools]
        DOCS[Documentation Sources<br/>vendor specs, RFCs]
        COMPLY[Compliance Frameworks<br/>SOC2 / HIPAA / GDPR]
        CICD[CI / CD Systems]
        CLOUD[Cloud Providers<br/>AWS / GCP / Azure]
        IDE[IDE / CLI Clients<br/>Claude Code / Cursor]
    end

    %% =============================================================
    %% c1v Dual-Mode Platform — 14 subsystems (SS1..SS14)
    %% =============================================================
    subgraph C1V["c1v Dual-Mode Platform"]
        direction TB
        SS1[SS1 Founder Web UI]
        SS2[SS2 Session Manager<br/>mode lock: cloud default / local opt-in]
        SS3[SS3 Agent Orchestrator<br/>LangGraph]
        SS4[SS4 LLM Provider Layer]
        SS5[SS5 Prompt Cache<br/>≥70% hit rate target]
        SS6[SS6 Spec Generator<br/>Mermaid v1]
        SS7[SS7 Traceback Store<br/>TTL 24h · refresh 7d]
        SS8[SS8 CLI Bundle Emitter<br/>≤5 MB bundle]
        SS9[SS9 Probe SDK<br/>customer-side]
        SS10[SS10 Metrics Collector]
        SS11[SS11 Metric Store<br/>60-min window]
        SS12[SS12 Recommendation Engine]
        SS13[SS13 Auth / Credential Vault<br/>90d rotation]
        SS14[SS14 Audit Log Store<br/>90d retention]
    end

    %% =============================================================
    %% External → c1v (inbound)
    %% =============================================================
    FOUND -- "IF-EXT-01 · UI events · HTTPS+SSE · ≤50 ms/chunk (EC16)" --> SS1
    IDP   -- "IF-EXT-02 · auth grant · OIDC/SAML · read-only scope (I.EXT.1)" --> SS13
    DOCS  -- "IF-EXT-06 · vendor specs · RAG retrieval · refresh 7d (EC11)" --> SS7
    CUST  -- "IF-EXT-05 · read-only handles · ≤2% overhead ceiling (EC1/EC3)" --> SS9

    %% =============================================================
    %% c1v → External (outbound)
    %% =============================================================
    SS4  -- "IF-EXT-03 · prompts → completions · ≤8000 tok (EC8) · ≤50 ms/chunk (EC16)" --> LLM
    SS8  -- "IF-EXT-04 · signed CLI bundle · ≤5 MB (EC14)" --> VCS
    SS8  -- "IF-EXT-10 · SKILL.md + CLAUDE.md + MCP defs · signed artifact" --> IDE
    SS8  -- "IF-EXT-08 · spec as gate · GH Actions hooks" --> CICD
    SS4  -- "IF-EXT-09 · service catalogs + SLAs" --> CLOUD
    SS14 -- "IF-EXT-07 · compliance evidence export · 90d retention (EC18)" --> COMPLY

    %% =============================================================
    %% c1v ↔ c1v (internal data flows — IF-01..IF-32)
    %% =============================================================
    %% UI boot + streaming
    SS1  -- "IF-01 · login + mode select · HTTPS POST (EC15)" --> SS2
    SS2  -- "IF-02 · session + intake stream · SSE ≤50 ms/chunk (EC16)" --> SS1
    SS1  -- "IF-31 · spec approvals + edits (EC13)" --> SS6
    SS6  -- "IF-32 · rendered Mermaid artifacts (EC12/EC13)" --> SS1

    %% Orchestration
    SS2  -- "IF-03 · dispatch (mode LOCKED before dispatch) · EC5↔EC6 roof" --> SS3
    SS3  -- "IF-04 · agent run state · ≤5 concurrent (EC6) · ≤8000 tok (EC8)" --> SS2
    SS2  -- "IF-09 · per-session routing policy (EC5, scale 2)" --> SS4

    %% Cache + LLM
    SS3  -- "IF-05 · prompt hash + cache key (EC7)" --> SS5
    SS5  -- "IF-06 · hit payload / miss signal (≥70% hit target, EC7)" --> SS3
    SS3  -- "IF-07 · prompt + tools + ctx (cache-miss only, ≤8000 tok EC8)" --> SS4
    SS4  -- "IF-08 · completion + tool calls · streamed (EC8/EC16)" --> SS3
    SS5  -- "IF-10 · cache-assisted call (prefix reuse, EC7+EC8)" --> SS4

    %% Spec generation + citation gate
    SS3  -- "IF-11 · generate spec req · Mermaid v1 (EC12) · 5 steps (EC13)" --> SS6
    SS6  -- "IF-12 · draft URI + pending-review (gated by IF-13/14)" --> SS3
    SS6  -- "IF-13 · citation check batch · HARD floor 100% (EC10)" --> SS7
    SS7  -- "IF-14 · traced citations · TTL=24h (EC9), refresh 7d (EC11)" --> SS6

    %% CLI emission
    SS3  -- "IF-15 · emit CLI bundle req (citation-gate must PASS)" --> SS8
    SS8  -- "IF-16 · receipt + signature + VCS ref (EC14)" --> SS3

    %% Probe pipeline (customer boundary)
    SS9  -- "IF-17 · probe payload · ≤6/min (EC1), ≤4 KB (EC3), batch ≥50 (EC4), 60-min flush (EC2)" --> SS10
    SS10 -- "IF-18 · backpressure + SDK config · reject-on-violation" --> SS9
    SS10 -- "IF-19 · aggregated write · 60-min window (EC2)" --> SS11
    SS11 -- "IF-20 · aggregated series + deviations · pull (EC2)" --> SS12

    %% Recommendation feedback
    SS12 -- "IF-21 · citation lookup for recs (EC9/EC10)" --> SS7
    SS7  -- "IF-22 · cited refs (TTL 24h, EC9/EC10)" --> SS12
    SS12 -- "IF-23 · cited recommendation → next-iteration spec (F.6→F.2)" --> SS3

    %% Audit
    SS3  -- "IF-24 · orchestration audit (EC18 90d)" --> SS14
    SS8  -- "IF-25 · CLI emission audit (EC18+EC14)" --> SS14
    SS10 -- "IF-26 · probe-rejection audit (EC18+EC1, I.EXT.9)" --> SS14

    %% Auth / Credentials
    SS13 -- "IF-27 · signed session JWT (EC17)" --> SS2
    SS2  -- "IF-28 · rotation trigger · 90d cadence (EC17)" --> SS13
    SS13 -- "IF-29 · provider credentials + mode flag (EC17+EC5)" --> SS4
    SS13 -- "IF-30 · read-only VCS+Obs handles · WRITE-SCOPE REJECTED (UC11)" --> SS9

    %% =============================================================
    %% Styling
    %% =============================================================
    classDef ui       fill:#E0E0FF,stroke:#333,stroke-width:1px;
    classDef engine   fill:#FFE0E0,stroke:#333,stroke-width:1px;
    classDef data     fill:#FFF3E0,stroke:#333,stroke-width:1px;
    classDef platform fill:#E0FFE0,stroke:#333,stroke-width:1px;
    classDef external fill:#F0F0F0,stroke:#555,stroke-dasharray: 5 5;
    class SS1 ui;
    class SS3,SS4,SS6,SS8,SS10,SS12 engine;
    class SS5,SS7,SS11,SS14 data;
    class SS2,SS13 platform;
    class SS9 external;
    class FOUND,IDP,LLM,VCS,CUST,DOCS,COMPLY,CICD,CLOUD,IDE external;

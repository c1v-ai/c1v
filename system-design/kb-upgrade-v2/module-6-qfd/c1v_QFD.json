    "_note": "1-5 customer perception (1=poor, 5=excellent). A = c1v Dual-Mode Platform; B = Devin (Cognition); C = Cursor (Anysphere).",
    "_competitor_b_name": "Devin (Cognition)",
    "_competitor_c_name": "Cursor (Anysphere)",
    "PC.1": {
      "A_low": 3,
      "A_high": 5,
      "A_target": 4,
      "B": 5,
      "C": 5,
      "rationale": "c1v probes customer prod at 2% ceiling; Devin/Cursor do not touch customer prod systems (trivially non-invasive)."
    },
    "PC.2": {
      "A_low": 3,
      "A_high": 4,
      "A_target": 3,
      "B": 1,
      "C": 1,
      "rationale": "c1v purpose-built for metric→recommendation loop (60 min target); Devin/Cursor do not implement this category."
    },
    "PC.3": {
      "A_low": 5,
      "A_high": 5,
      "A_target": 5,
      "B": 2,
      "C": 2,
      "rationale": "c1v enforces 100% traceback (PC.3 Final); Devin cites ~30-40% of suggestions, Cursor ~20-30%."
    },
    "PC.4": {
      "A_low": 2,
      "A_high": 4,
      "A_target": 3,
      "B": 2,
      "C": 3,
      "rationale": "c1v target 300s; Devin 600-900s for full spec work; Cursor 30-60s but produces IDE-level scaffolding, not structured PRD."
    },
    "PC.5": {
      "A_low": 3,
      "A_high": 5,
      "A_target": 4,
      "B": 1,
      "C": 1,
      "rationale": "c1v emits CLI bundle in 60s target; Devin/Cursor have no equivalent signed-bundle deliverable."
    },
    "PC.6": {
      "A_low": 2,
      "A_high": 4,
      "A_target": 3,
      "B": 2,
      "C": 5,
      "rationale": "c1v web-streaming UI ~2000 ms/turn; Devin ~3000-5000 ms; Cursor ~500-1500 ms (IDE-embedded, local context)."
    }
  },

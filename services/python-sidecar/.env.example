# c1v python-sidecar environment.
# Production values come from Cloud Run Secret Manager (cloud-run.yaml refs).
# Copy to .env for local dev only — NEVER commit secrets.

# --- Supabase (service-role; writes bypass RLS — sidecar-only key) ----------
SUPABASE_URL=https://yxginqyxtysjdkeymnon.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
ARTIFACT_STORAGE_BUCKET=project-artifacts

# --- Generator runtime ------------------------------------------------------
GENERATORS_DIR=/app/generators
GENERATOR_TIMEOUT_S=240

# --- Sidecar HTTP -----------------------------------------------------------
PORT=8080
LOG_LEVEL=INFO

# --- Local-only ops -------------------------------------------------------
# Set to 1 to skip Supabase upserts + storage uploads (orchestrator logs the
# would-be writes). Used by orchestrator.test.py and ad-hoc local debugging.
SIDECAR_DRY_RUN=0

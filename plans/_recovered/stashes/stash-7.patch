-  "use_case_flows": [
-    {
-      "use_case_id": "UC01",
-      "use_case_name": "Generate Spec from One-Sentence Idea",
-      "function_sequence": [
-        "authenticate_session", "persist_idea_prompt", "initiate_intake_session", "present_intake_question",
-        "classify_idea_domain", "loop_intake_to_threshold", "assemble_scope_outline", "draft_tech_stack_recommendation",
-        "invoke_metric_traceback", "assemble_spec_bundle", "validate_spec_schema", "enforce_spec_generation_timeout",
-        "persist_spec_versioned", "write_audit_entry", "notify_reviewers", "return_spec_location"
-      ],
-      "branching": [
-        { "after_function": "loop_intake_to_threshold", "branches": [
-          { "guard": "not_complete", "next_function": "present_intake_question" },
-          { "guard": "complete", "next_function": "assemble_scope_outline" }
-        ] },
-        { "after_function": "validate_spec_schema", "branches": [
-          { "guard": "valid", "next_function": "enforce_spec_generation_timeout" },
-          { "guard": "invalid", "next_function": "emit_structured_error" }
-        ] }
-      ]
-    },
-    {
-      "use_case_id": "UC03",
-      "use_case_name": "Review Generated Spec",
-      "function_sequence": [
-        "authenticate_session", "enumerate_review_queue", "render_review_queue", "verify_review_permission",
-        "load_spec_bundle", "render_spec_view", "persist_review_comment", "validate_revision_comment",
-        "transition_spec_state", "write_audit_entry", "notify_founder_of_review", "gate_cli_emission_on_approval",
-        "notify_engineers_of_approval"
-      ],
-      "branching": [
-        { "after_function": "transition_spec_state", "branches": [
-          { "guard": "approved", "next_function": "gate_cli_emission_on_approval" },
-          { "guard": "rejected", "next_function": "notify_founder_of_review" },
-          { "guard": "revisions_requested", "next_function": "notify_founder_of_review" }
-        ] }
-      ]
-    },
-    {
-      "use_case_id": "UC04",
-      "use_case_name": "Emit CLI Commands from Spec",
-      "function_sequence": [
-        "authenticate_session", "verify_spec_approved", "verify_emit_permission", "load_spec_bundle",
-        "generate_skill_md", "generate_claude_md", "generate_mcp_tool_definition", "package_cli_bundle",
-        "sign_cli_bundle", "enforce_cli_emission_timeout", "write_bundle_to_vcs", "deliver_bundle_to_client",
-        "require_receipt_token", "write_audit_entry", "return_bundle_location"
-      ],
-      "branching": [],
-      "parallel": [
-        { "at_function": "enforce_cli_emission_timeout", "parallel_functions": ["write_bundle_to_vcs", "deliver_bundle_to_client"], "join_at": "write_audit_entry" }
-      ]
-    },
-    {
-      "use_case_id": "UC06",
-      "use_case_name": "Recommend Design Improvements",
-      "function_sequence": [
-        "persist_metric_sample", "enforce_customer_overhead_budget", "aggregate_metric_window",
-        "compare_aggregate_to_target", "compute_metric_deviation", "suppress_noise_deviations",
-        "propose_candidate_improvements", "link_recommendation_to_metric", "rank_recommendations",
-        "cap_recommendation_list", "deliver_recommendation_list", "notify_pm_of_cycle",
-        "write_audit_entry", "persist_recommendation_action", "surface_feature_candidate",
-        "enforce_read_only_posture"
-      ],
-      "branching": [
-        { "after_function": "persist_recommendation_action", "branches": [
-          { "guard": "missing_functionality", "next_function": "surface_feature_candidate" },
-          { "guard": "not_missing", "next_function": "enforce_read_only_posture" }
-        ] }
-      ]
-    },
-    {
-      "use_case_id": "UC08",
-      "use_case_name": "Trace Tech-Stack Recommendation to Metric",
-      "function_sequence": [
-        "receive_draft_recommendation", "parse_recommendation", "classify_capability_metric",
-        "query_documentation_sources", "query_cloud_providers", "resolve_metric_value",
-        "validate_external_citation", "compute_traceback_confidence", "record_traceback_triple",
-        "flag_low_confidence_recommendation", "attach_traceback_to_spec", "enforce_traceback_coverage",
-        "write_audit_entry", "return_traced_recommendation"
-      ],
-      "branching": [
